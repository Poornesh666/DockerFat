pipeline {
    agent any
    environment {
        DOCKER_IMAGE = 'poornesh666/merchandise-site'
        DOCKER_TAG = "${BUILD_NUMBER}"
        DOCKER_CREDENTIALS = credentials('dockerhub')
    }
    stages {
        stage('Checkout') {
            steps {
                echo '========== Checking out code =========='
                checkout scm
                echo 'Code checked out successfully'
            }
        }
        stage('Build Docker Image') {
            steps {
                echo '========== Building Docker image =========='
                script {
                    bat """
                        echo Building image: %DOCKER_IMAGE%:%DOCKER_TAG%
                        docker build -t %DOCKER_IMAGE%:%DOCKER_TAG% .
                        docker tag %DOCKER_IMAGE%:%DOCKER_TAG% %DOCKER_IMAGE%:latest
                        docker images | findstr merchandise-site
                    """
                }
                echo 'Docker image built successfully'
            }
        }
        stage('Push to Docker Hub') {
            steps {
                echo '========== Pushing image to Docker Hub =========='
                script {
                    bat """
                        echo Logging into Docker Hub...
                        docker login -u %DOCKER_CREDENTIALS_USR% -p %DOCKER_CREDENTIALS_PSW%
                        echo Pushing %DOCKER_IMAGE%:%DOCKER_TAG%...
                        docker push %DOCKER_IMAGE%:%DOCKER_TAG%
                        echo Pushing %DOCKER_IMAGE%:latest...
                        docker push %DOCKER_IMAGE%:latest
                        echo Image pushed successfully
                    """
                }
            }
        }
        stage('Deploy to Kubernetes') {
            steps {
                echo '========== Deploying to Kubernetes =========='
                script {
                    bat """
                        kubectl set image deployment/html-demo html-demo=%DOCKER_IMAGE%:latest
                        kubectl rollout status deployment/html-demo
                    """
                }
                echo 'Deployment completed successfully'
            }
        }
        stage('Verification') {
            steps {
                echo '========== Verifying deployment =========='
                script {
                    bat """
                        kubectl get deployment html-demo
                        kubectl get pods -l app=html-demo
                        kubectl get svc html-demo-service
                    """
                }
                echo 'Verification completed'
            }
        }
    }
    post {
        success {
            echo 'Merchandise site successfully deployed!'
            echo 'Access at: http://<node-ip>:30010'
        }
        failure {
            echo 'Pipeline failed. Check logs above.'
        }
    }
}
